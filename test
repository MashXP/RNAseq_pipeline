#!/bin/bash

# [[test]]
# Master Execution Runner for the RNA-seq Verification Suite.
# Usage: ./test {up|down|all}
# Divergence from Prod: Redirects all IO to test folders; enforces Chr21 mode.

set -e

# --- Logging Setup ---
LOG_DIR="$(dirname "$(realpath "$0")")/_data/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/test_$(date +%Y%m%d_%H%M%S).log"
exec > >(tee -a "$LOG_FILE") 2>&1
echo "Log file: $LOG_FILE"
# ---------------------

echo "========================================================="
echo "   RNA-seq Pipeline - TEST SUITE (Chr21)"
echo "========================================================="

# 1. Environment Check
if [[ "$CONDA_DEFAULT_ENV" != "cancer_rnaseq" ]]; then
    echo "ERROR: 'cancer_rnaseq' environment is not active."
    echo "Please run: micromamba activate cancer_rnaseq  # or mamba/conda"
    exit 1
fi

# 2. Argument Logic
RUN_UPSTREAM=false
RUN_DOWNSTREAM=false

if [ "$#" -eq 0 ]; then
    echo "Usage: ./test {up|down|all}"
    exit 1
fi

for arg in "$@"; do
    case $arg in
        up) RUN_UPSTREAM=true ;;
        down) RUN_DOWNSTREAM=true ;;
        all) RUN_UPSTREAM=true; RUN_DOWNSTREAM=true ;;
        *) echo "Unknown argument: $arg"; exit 1 ;;
    esac
done

# 3. TEST UPSTREAM
if [ "$RUN_UPSTREAM" = true ]; then
    echo ">>> Running TEST UPSTREAM (Chr21)..."
    (
        cd test_upstream/
        bash test_01_genome_prep.sh
        bash test_02_star_align.sh
        bash test_03_rseqc_qc.sh
        bash test_04_quantification.sh
        bash test_05_multiqc.sh
    )
fi

# 4. TEST DOWNSTREAM
if [ "$RUN_DOWNSTREAM" = true ]; then
    echo ">>> Running TEST DOWNSTREAM (Low Threshold)..."
    (
        cd test_downstream/
        
        CSV_FILE="../drPhuong_Sample_Data_Table.csv"
        # Extract groups from CSV
        groups=$(python3 "../test_upstream/utils/parse_samples.py" "$CSV_FILE" | awk '{print $5}' | sort -u)

        for group in $groups; do
            echo "========================================================="
            echo "Running test downstream analysis for Group: $group"
            echo "========================================================="

            # Get species for this group
            species=$(python3 "../test_upstream/utils/parse_samples.py" "$CSV_FILE" | awk -v grp="$group" '$5 == grp {print $4}' | head -n 1)
            
            echo "-> Species detected: $species"

            Rscript test_01_data_prep.R "$group" "$species"
            Rscript test_02_deseq2_dge.R "$group" "$species"
            Rscript test_03_enrichment.R "$group" "$species"
            
            # Module 04: Visualizations
            Rscript test_04_01_pca.R "$group" "$species"
            Rscript test_04_02_volcano.R "$group" "$species"
            Rscript test_04_03_venn.R "$group" "$species"
            Rscript test_04_04_heatmap_pathway.R "$group" "$species"
            Rscript test_04_05_heatmap_variable.R "$group" "$species"
            Rscript test_04_06_enrichment_nes.R "$group" "$species"
            Rscript test_04_07_enrichment_dotplot.R "$group" "$species"

            echo "Done with Group: $group"
        done
    )
fi

echo "========================================================="
echo "   TEST SUITE COMPLETED SUCCESSFULLY"
echo "========================================================="
