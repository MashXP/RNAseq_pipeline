#!/bin/bash

# run
# Master script for the RNA-seq Pipeline

# Exit on error
set -e

# --- Project Root Discovery ---
export PROJECT_ROOT="$(dirname "$(realpath "$0")")"
# ------------------------------

# --- Logging Setup ---
LOG_DIR="$PROJECT_ROOT/_data/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/run_$(date +%Y%m%d_%H%M%S).log"
exec > >(tee -a "$LOG_FILE") 2>&1
echo "Log file: $LOG_FILE"
# ---------------------

echo "========================================================="
echo "   RNA-seq Pipeline - Pipeline Runner"
echo "   Starting at: $(date)"
echo "========================================================="

# --- Resource Detection ---
export THREADS=${SLURM_CPUS_PER_TASK:-$(nproc 2>/dev/null || echo 16)}
if [ -n "$SLURM_MEM_PER_NODE" ]; then
    export MEM_GB=$(($SLURM_MEM_PER_NODE / 1024))
else
    export MEM_GB=$(free -g 2>/dev/null | awk '/^Mem:/{print $2}' || echo 128)
fi
echo "   Resources: $THREADS threads, $MEM_GB GB RAM detected."
echo "---------------------------------------------------------"

# 1. Environment Check
if [[ "$CONDA_DEFAULT_ENV" != "cancer_rnaseq" ]]; then
    echo "WARNING: The 'cancer_rnaseq' environment is not active."
    echo ""
    read -p "Do you want to proceed using system tools? [y/N]: " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborting. Please activate the environment."
        exit 1
    fi
fi

# 2. Argument Logic
RUN_CORE=false
RUN_DGE=false
RUN_AS=false

if [ "$#" -eq 0 ]; then
    echo "Usage: ./run {core|dge|as|all}"
    exit 1
fi

for arg in "$@"; do
    case $arg in
        core) RUN_CORE=true ;;
        dge)  RUN_DGE=true ;;
        as)   RUN_AS=true ;;
        all)  RUN_CORE=true; RUN_DGE=true; RUN_AS=true ;;
        script)
            if [ "$#" -lt 2 ]; then
                echo "Usage: ./run script <path_to_script> [args...]"
                exit 1
            fi
            SCRIPT_PATH="$2"
            shift 2
            echo ">>> Running Individual Script: $SCRIPT_PATH"
            # Extract directory and filename
            SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
            SCRIPT_FILE=$(basename "$SCRIPT_PATH")
            (
                cd "$SCRIPT_DIR"
                if [[ "$SCRIPT_FILE" == *.sh ]]; then
                    bash "$SCRIPT_FILE" "$@"
                elif [[ "$SCRIPT_FILE" == *.R ]]; then
                    Rscript "$SCRIPT_FILE" "$@"
                else
                    echo "Unknown script type: $SCRIPT_FILE"
                    exit 1
                fi
            )
            exit 0
            ;;
        *)    echo "Unknown argument: $arg. Use 'core', 'dge', 'as', 'all', or 'script'."; exit 1 ;;
    esac
done

# 3. CORE ALIGNMENT
if [ "$RUN_CORE" = true ]; then
    echo ">>> Running CORE ALIGNMENT Module..."
    (
        cd 01_core_alignment/scripts/
        bash 01_genome_prep.sh
        bash 02_star_align.sh
        bash 03_alignment_qc.sh
        bash 04_multiqc.sh
    ) || { echo "Core Alignment failed. Exiting."; exit 1; }
    echo "CORE ALIGNMENT COMPLETE."
    echo ""
fi

# 4. DGE ANALYSIS
if [ "$RUN_DGE" = true ]; then
    echo ">>> Running DGE ANALYSIS Module..."
    
    # Species-level Analysis
    CSV_FILE="_data/_metadata/drPhuong_Sample_Data_Table.csv"
    species_list=$(python3 "utils/parse_samples.py" "$CSV_FILE" | awk '{print $4}' | sort -u)

    (
        # Upstream DGE
        cd 02_dge_analysis/scripts/upstream/
        bash 01_quantification.sh
        
        # Downstream DGE
        cd ../downstream/
        for species in $species_list; do
            echo "--- Processing Species: $species ---"
            Rscript 01_data_prep.R "$species"
            Rscript 02_deseq2_dge.R "$species"
            Rscript 03_enrichment.R "$species"
            
            Rscript 04_pca.R "$species"
            Rscript 05_volcano.R "$species"
            Rscript 06_venn.R "$species"
            Rscript 07_heatmap_pathway.R "$species"
            Rscript 08_heatmap_variable.R "$species"
            Rscript 09_enrichment_nes.R "$species"
            Rscript 10_enrichment_dotplot.R "$species"
            Rscript 11_ora_dotplot.R "$species"
            Rscript 12_upset_consistency.R "$species"
            Rscript 13_correlation_plots.R "$species"
        done

        # Comparative
        echo "--- Running Comparative DGE Analysis ---"
        Rscript 14_alluvial_plot.R
        Rscript 15_ortholog_gene_overlap.R
        Rscript 16_ortholog_nes_overlap.R
    ) || { echo "DGE Analysis failed. Exiting."; exit 1; }
    echo "DGE ANALYSIS COMPLETE."
    echo ""
fi

# 5. AS ANALYSIS
if [ "$RUN_AS" = true ]; then
    echo ">>> Running ALTERNATIVE SPLICING Module..."
    (
        # Upstream AS
        cd 03_as_analysis/scripts/upstream/
        bash 01_rmats_splicing.sh
        
        # Downstream AS
        cd ../downstream/
        Rscript 01_rmats_summary.R
        # bash 02_rmats_sashimi.sh  # Optional/Manual usually
    ) || { echo "AS Analysis failed. Exiting."; exit 1; }
    echo "AS ANALYSIS COMPLETE."
    echo ""
fi

echo "========================================================="
echo "   All requested modules completed successfully."
echo "   Completed at: $(date)"
echo "========================================================="
