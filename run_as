#!/bin/bash
#SBATCH --job-name=rMATS_Turbo_Parallel
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --mem=128G
#SBATCH --time=24:00:00
#SBATCH --array=0-11
#SBATCH --output=_data/logs/rmats_array_%A_%a.log
#SBATCH --error=_data/logs/rmats_array_%A_%a.err

# [[run_as]]
# Slurm wrapper for parallel rMATS-turbo execution.
# This script uses Slurm Job Arrays to run each of the 12 cell-line/drug comparisons
# in parallel across different nodes (if available) or sequentially on allocated resources.

# 1. Initialize environment (Safe method for batch shells)
eval "$(micromamba shell hook --shell bash)"
micromamba activate cancer_rnaseq

# 2. Define the script path
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
RMATS_SCRIPT="$SCRIPT_DIR/scripts_upstream/06_rmats_splicing.sh"

# 3. Execution
echo "========================================================="
echo "   rMATS-turbo Parallel Run (Job ID: $SLURM_ARRAY_JOB_ID, Task: $SLURM_ARRAY_TASK_ID)"
echo "   Starting at: $(date)"
echo "========================================================="

# We pass the SLURM_ARRAY_TASK_ID to the script, which now knows how to handle it.
bash "$RMATS_SCRIPT" "$SLURM_ARRAY_TASK_ID"

echo "========================================================="
echo "   Task $SLURM_ARRAY_TASK_ID completed at: $(date)"
echo "========================================================="
